---
import Base from "../layouts/Base.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Stat from "../components/ui/Stat.astro";
import Tag from "../components/ui/Tag.astro";
import AnomalyChart from "../components/anomalies/AnomalyChart";
import anomalies from "../data/anomalies.json";

// Real aggregates from the weekly aisstream listening sessions
// (scripts/fetch-anomalies.mjs). Aggregated by zone ONLY:
// no vessel name, no MMSI, no IMO, ever — that guardrail is the module.
const HEURISTIC_META: Record<string, { name: string; tag: number; desc: string }> = {
  "jamming-cluster": { name: "Jamming cluster", tag: 6, desc: "Many vessels in one area simultaneously reporting displaced or circular positions: the signature of area GPS interference, not of any single ship." },
  "impossible-jump": { name: "Impossible jump", tag: 3, desc: "A position sequence implying a speed no hull can reach. Flags teleporting tracks caused by spoofed or corrupted broadcasts." },
  "speed-anomaly": { name: "Speed anomaly", tag: 2, desc: "Reported speed over ground far outside a vessel class's envelope, sustained across several messages." },
  "dark-gap": { name: "Dark gap", tag: 5, desc: "A prolonged silence from a transponder inside a sensitive zone, bounded by normal broadcasts before and after. Counted only above a duration threshold." },
  "position-on-land": { name: "Position on land", tag: 4, desc: "Broadcast coordinates that place a vessel solidly inland. Almost always interference or spoofing; occasionally a misconfigured transponder." },
};
const HEURISTIC_IDS = Object.keys(HEURISTIC_META);

type Session = (typeof anomalies.sessions)[number];
const sessions: Session[] = anomalies.sessions;
const weeks = [...new Set(sessions.map((s) => s.week))];
const weekLabels = weeks.map((w) => w.slice(5));
const zoneIds = [...new Set(sessions.flatMap((s) => Object.keys(s.zones)))];

const zoneTotal = (s: Session, id: string) => {
  const z = (s.zones as any)[id];
  return z ? (Object.values(z.counts) as number[]).reduce((a, b) => a + b, 0) : 0;
};
// zones × weeks matrix (sessions in the same ISO week are summed)
const ZONES = zoneIds.map((id) => {
  const name = (sessions.find((s) => (s.zones as any)[id])?.zones as any)[id].name as string;
  const counts = weeks.map((w) => sessions.filter((s) => s.week === w).reduce((a, s) => a + zoneTotal(s, id), 0));
  return { id, name, counts };
});
const max = Math.max(1, ...ZONES.flatMap((z) => z.counts));

const last = weeks.length - 1;
const lastWeek = weekLabels[last];
const totalLast = ZONES.reduce((a, z) => a + z.counts[last], 0);
const totalPrev = last > 0 ? ZONES.reduce((a, z) => a + z.counts[last - 1], 0) : null;
const topZone = [...ZONES].sort((a, b) => b.counts[last] - a.counts[last])[0];
const lastSessions = sessions.filter((s) => s.week === weeks[last]);
const vesselsLast = lastSessions.reduce((a, s) => a + Object.values(s.zones as any).reduce((x: number, z: any) => x + z.vessels, 0), 0);
const minutesLast = lastSessions.reduce((a, s) => a + s.minutes, 0);

// weekly totals by heuristic for the chart
const chartRows = weeks.flatMap((w, i) =>
  HEURISTIC_IDS.map((h) => ({
    week: weekLabels[i],
    heuristic: HEURISTIC_META[h].name,
    count: sessions.filter((s) => s.week === w).reduce((a, s) => a + (Object.values(s.zones as any) as any[]).reduce((x, z) => x + (z.counts[h] ?? 0), 0), 0),
  })),
);
---

<Base
  title="AIS Integrity Watch · Le Phare"
  description="Weekly AIS integrity anomalies aggregated by zone: jamming clusters, impossible jumps, dark gaps, positions on land. Never by vessel."
>
  <SiteHeader />

  <div class="mx-auto max-w-[1320px] px-6">
    <section class="border-b border-line py-16 md:py-20">
      <h1 class="t-display max-w-[16ch] text-[clamp(2.4rem,5vw,4rem)]">
        AIS Integrity Watch
      </h1>
      <p class="mt-6 max-w-[58ch] text-lg leading-relaxed text-ink-2">
        Where the world's positioning signal stops being trustworthy, week by
        week. Five heuristics over public AIS, aggregated by zone.
      </p>
      <p class="t-meta mt-4">
        Live aisstream.io sampling sessions, all six zones at once ·
        aggregated by zone only, never a vessel name, MMSI or IMO ·
        history accumulates weekly
      </p>
    </section>

    <!-- Weekly stats -->
    <section class="border-b border-line py-12">
      <div class="grid gap-8 sm:grid-cols-3 sm:divide-x sm:divide-[color:var(--line)] sm:[&>*]:px-8 sm:[&>*:first-child]:pl-0">
        <Stat
          value={totalLast}
          label={`Anomalies flagged · ${lastWeek}`}
          detail={totalPrev != null ? `${totalLast - totalPrev >= 0 ? "+" : ""}${totalLast - totalPrev} vs ${weekLabels[last - 1]}` : `first session · ${minutesLast} min sampled`}
          accent
        />
        <Stat value={topZone.counts[last]} label={`${topZone.name} · ${lastWeek}`} detail="highest zone this week" />
        <Stat value={vesselsLast} label={`Vessels observed · ${lastWeek}`} detail={`across ${zoneIds.length} zones, ${minutesLast} min of listening`} />
      </div>
    </section>

    <!-- Heatmap -->
    <section class="border-b border-line py-14">
      <h2 class="t-serif mb-2 text-3xl">Zones × weeks</h2>
      <p class="mb-8 max-w-[60ch] text-sm text-ink-2">
        Flagged anomalies per zone per week, all heuristics combined. The
        brighter the cell, the noisier the zone.
        {weeks.length < 4 && " The watch is young: columns accumulate one per week."}
      </p>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm" style="min-width:640px">
          <thead>
            <tr>
              <th class="t-caps pb-3 pr-4 text-left font-semibold">Zone</th>
              {weekLabels.map((w) => <th class="t-meta pb-3 text-center">{w}</th>)}
            </tr>
          </thead>
          <tbody>
            {
              ZONES.map((z) => (
                <tr class="border-t border-line">
                  <td class="whitespace-nowrap py-1.5 pr-4 text-ink">{z.name}</td>
                  {z.counts.map((c) => (
                    <td class="p-1">
                      <span
                        class="t-num flex h-11 items-center justify-center font-mono text-[13px]"
                        style={`background: color-mix(in srgb, var(--accent) ${Math.round((c / max) * 72)}%, transparent); color: ${c / max > 0.55 ? "var(--accent-ink)" : "var(--ink-2)"}`}
                      >
                        {c}
                      </span>
                    </td>
                  ))}
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <p class="t-meta mt-3">Live sampled AIS via aisstream.io · Graphic: Le Phare</p>
    </section>

    <!-- Weekly trend by heuristic -->
    <section class="border-b border-line py-14">
      <div class="grid gap-12 lg:grid-cols-12">
        <div class="lg:col-span-6">
          <h2 class="t-serif mb-2 text-3xl">What kind of noise</h2>
          <p class="mb-6 max-w-[52ch] text-sm text-ink-2">
            Weekly totals by heuristic, from the same sampled sessions.
            Interference clusters and displaced positions concentrate where
            the shooting is; the rest is the long tail of a degraded signal
            environment.
          </p>
          <AnomalyChart rows={chartRows} client:visible />
          <p class="t-meta mt-3">Live sampled AIS · Graphic: Le Phare</p>
        </div>
        <div class="lg:col-span-6">
          <h2 class="t-serif mb-6 text-3xl">The five heuristics</h2>
          <dl class="grid gap-6">
            {
              HEURISTIC_IDS.map((h) => (
                <div class="border-t border-line-2 pt-3">
                  <dt class="flex items-center gap-3">
                    <Tag label={HEURISTIC_META[h].name} viz={HEURISTIC_META[h].tag as 2 | 3 | 4 | 5 | 6} />
                  </dt>
                  <dd class="mt-2 max-w-[58ch] text-sm leading-relaxed text-ink-2">{HEURISTIC_META[h].desc}</dd>
                </div>
              ))
            }
          </dl>
        </div>
      </div>
    </section>

    <!-- Method note -->
    <section class="border-b border-line py-12">
      <h2 class="t-caps mb-4">How the watch samples</h2>
      <p class="max-w-[62ch] text-sm leading-relaxed text-ink-2">
        Each week the pipeline opens one live aisstream.io connection
        covering all six zones and listens for a bounded session (~12
        minutes), applying the five heuristics to the raw position stream in
        memory. Only zone-level counts are kept. Sampling means the numbers
        are a floor, not a census — comparable week to week because the
        method never changes, and biased low everywhere shore-receiver
        coverage is thin (Hormuz notably, where jamming also suppresses
        reception).
      </p>
    </section>

    <!-- Privacy stance -->
    <section class="py-12">
      <p class="t-serif max-w-[58ch] text-xl !text-[color:var(--ink-2)]">
        This module never names a ship. Anomaly detection points at zones and
        signal environments, not at vessels: attribution from open AIS alone
        is unreliable, and this observatory does not do name-and-shame.
      </p>
    </section>
  </div>

  <SiteFooter />
</Base>
