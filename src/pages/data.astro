---
import Base from "../layouts/Base.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import DataLab from "../components/data/DataLab";

const datasets = [
  { name: "Chokepoint transit calls", src: "IMF PortWatch", cadence: "daily · ~5 day lag · updated weekly", span: "2024 → today", href: "#lab", note: "Loaded in the lab below." },
  { name: "Maritime incidents", src: "ASAM + ReCAAP + IMB, auto-ingested", cadence: "refreshed with each data update", span: "2022 → today", href: "/incidents", note: "Explored on the incidents page." },
  { name: "Live strait AIS", src: "Digitraffic + aisstream.io", cadence: "live · 13 straits", span: "now", href: "/straits", note: "Live panel on the strait monitor." },
  { name: "News wire mentions", src: "GDELT", cadence: "snapshot every 6 h", span: "rolling 7 days", href: "/brief", note: "The wire on the brief page." },
];
---

<Base
  title="Data Lab · Le Phare"
  description="Build your own chart from the observatory's datasets: IMF PortWatch chokepoint transits, incident archives and live feeds. Export PNG, CSV and citations."
>
  <SiteHeader />

  <div class="mx-auto max-w-[1320px] px-6">
    <section class="border-b border-line py-16 md:py-20">
      <h1 class="t-display max-w-[14ch] text-[clamp(2.4rem,5vw,4rem)]">Data Lab</h1>
      <p class="mt-6 max-w-[56ch] text-lg leading-relaxed text-ink-2">
        The observatory's datasets, in your hands. Pick chokepoints, a metric
        and a transform; the chart follows the house style and leaves with
        you: PNG, CSV and a citation.
      </p>
    </section>

    <section class="border-b border-line py-10">
      <div class="grid gap-px bg-[color:var(--line)] sm:grid-cols-2 lg:grid-cols-4">
        {
          datasets.map((d) => (
            <a href={d.href} class="group flex flex-col justify-between gap-6 bg-bg-0 p-6 transition-colors duration-200 hover:bg-bg-1">
              <span>
                <span class="t-serif block text-lg transition-colors duration-200 group-hover:text-accent-text">{d.name}</span>
                <span class="t-caps mt-1 block">{d.src}</span>
              </span>
              <span class="t-meta">{d.cadence}<br />{d.span} · {d.note}</span>
            </a>
          ))
        }
      </div>
    </section>

    <section id="lab" class="scroll-mt-24 py-14">
      <DataLab client:load />
    </section>
  </div>

  <SiteFooter />
</Base>
