---
import "@fontsource-variable/fraunces";
import Base from "../layouts/Base.astro";
import Logo from "../components/Logo.astro";
import Icon from "../components/Icon.astro";
import Button from "../components/ui/Button.astro";
import Tag from "../components/ui/Tag.astro";
import Figure from "../components/ui/Figure.astro";
import Stat from "../components/ui/Stat.astro";
import Bathymetry from "../components/motifs/Bathymetry.astro";
import WindRose from "../components/motifs/WindRose.astro";
import { HeroLineChart, StackedBarChart, SmallMultiples } from "../components/charts/VizSamples";
import MapPanel from "../components/map/MapPanel";
import ParticleFlow from "../components/hero/ParticleFlow";

const darkColors = [
  { token: "--bg-0", hex: "#0A1622", role: "Page. The abyss is the paper." },
  { token: "--bg-1", hex: "#0E2233", role: "Raised panel, hover rows." },
  { token: "--bg-2", hex: "#14293D", role: "Active surface." },
  { token: "--ink", hex: "#E8EDF2", role: "Primary text." },
  { token: "--ink-2", hex: "#A9B8C6", role: "Secondary text." },
  { token: "--ink-3", hex: "#71869B", role: "Meta, captions, axes." },
  { token: "--accent", hex: "#F2B950", role: "The beam. CTA, hero series, critical data. Three appearances per screen, maximum." },
  { token: "--risk", hex: "#C0392B", role: "Incidents only. Never decorative." },
];

const contrast = [
  { pair: "ink on bg-0", ratio: "15.49", grade: "AAA" },
  { pair: "ink-2 on bg-0", ratio: "9.00", grade: "AAA" },
  { pair: "ink-3 on bg-0", ratio: "4.85", grade: "AA" },
  { pair: "accent on bg-0", ratio: "10.28", grade: "AAA" },
  { pair: "accent-ink on accent", ratio: "10.28", grade: "AAA" },
  { pair: "risk-text on bg-0", ratio: "5.56", grade: "AA" },
  { pair: "ink on bg-0 (light)", ratio: "14.88", grade: "AAA" },
  { pair: "ink-3 on bg-0 (light)", ratio: "4.64", grade: "AA" },
  { pair: "accent-text on bg-0 (light)", ratio: "5.16", grade: "AA" },
];

const vizSeries = [
  { n: 1, name: "Deep amber", use: "First series. Cargo." },
  { n: 2, name: "Teal", use: "Tanker." },
  { n: 3, name: "Periwinkle", use: "Container." },
  { n: 4, name: "Rose", use: "Passenger." },
  { n: 5, name: "Steel", use: "Bulk." },
  { n: 6, name: "Copper", use: "Other." },
];

const typeScale = [
  { name: "Hero display", cls: "t-display", size: "clamp(3rem, 7vw, 5.5rem)", sample: "The observatory" },
  { name: "Display", cls: "t-display", size: "3.25rem", sample: "Red Sea transits halve" },
  { name: "Heading 2", cls: "t-serif", size: "2rem", sample: "Weekly risk brief" },
  { name: "Heading 3", cls: "t-serif", size: "1.4rem", sample: "Chokepoint monitor" },
];

const icons = [
  { name: "drone", label: "Drone strike" },
  { name: "boarding", label: "Boarding" },
  { name: "seizure", label: "Seizure" },
  { name: "mine", label: "Mine" },
  { name: "hijack", label: "Hijack" },
  { name: "jamming", label: "GPS jamming" },
  { name: "vessel", label: "Vessel" },
  { name: "anchor", label: "Anchorage" },
  { name: "strait", label: "Chokepoint" },
  { name: "trend", label: "Trend" },
  { name: "external", label: "Source link" },
  { name: "arrow", label: "Navigation" },
] as const;
---

<Base
  title="Styleguide · Le Phare"
  description="Design system of Le Phare, the Maritime Risk Observatory."
>
  <!-- Top bar -->
  <header
    class="sticky top-0 z-50 border-b border-line bg-bg-0/90 backdrop-blur-sm"
  >
    <div class="mx-auto flex max-w-[1320px] items-center justify-between px-6 py-3">
      <span class="flex items-center gap-3">
        <Logo size={26} loop />
        <span class="font-serif text-lg font-medium tracking-tight">LE PHARE</span>
        <span class="t-meta hidden sm:inline">styleguide · v0.1</span>
      </span>
      <button
        id="theme-toggle"
        class="t-caps cursor-pointer border border-line-2 rounded-r1 px-3 py-1.5 !text-ink-2 transition-colors duration-200 hover:border-[color:var(--accent)] hover:!text-accent-text"
        aria-pressed="false"
      >
        Light mode
      </button>
    </div>
  </header>

  <div class="mx-auto max-w-[1320px] px-6">
    <!-- Masthead -->
    <section class="relative grid gap-10 overflow-hidden border-b border-line py-20 md:grid-cols-12">
      <Bathymetry class="absolute inset-0 h-full w-full" opacity={0.045} />
      <ParticleFlow client:load />
      <div class="relative md:col-span-8">
        <p class="t-caps mb-6" data-reveal>Design system · Phase 0</p>
        <h1 id="masthead-title" class="t-display text-[clamp(3rem,7vw,5.5rem)]">
          A lighthouse sweeping<br />the dark of the oceans.
        </h1>
        <p class="mt-8 max-w-[54ch] text-lg leading-relaxed text-ink-2" data-reveal>
          Le Phare reads like a publication and behaves like an instrument.
          The abyss is the paper, light is the ink, and the amber beam marks
          only what matters.
        </p>
      </div>
      <div class="relative hidden md:col-span-4 md:flex md:items-center md:justify-end">
        <WindRose size={230} opacity={0.1} />
      </div>
    </section>

    <!-- Principles -->
    <section class="border-b border-line py-16">
      <h2 class="t-serif mb-10 text-3xl" data-reveal>Five principles</h2>
      <ol class="grid gap-x-12 gap-y-8 md:grid-cols-2 lg:grid-cols-3" data-reveal-stagger>
        {
          [
            ["The chart carries the conclusion", "Figure titles are statements, not descriptions. One hero series in amber, context in muted blues, events annotated on the axis, source in mono below."],
            ["Darkness is the paper", "No borders where a 2 to 4 percent lightness step will do. Hairlines at 8 percent. Amber appears three times per screen at most; red only for incidents."],
            ["Serif argues, sans measures, mono locates", "Spectral for titles and editorial voice. Archivo for interface and labels. IBM Plex Mono for coordinates, timestamps and identifiers. Tabular figures wherever numbers meet."],
            ["Density in layers, finish at the pixel", "The number first, the trend second, the detail on hover. Transitions of 150 to 250 ms with a pronounced ease-out. Every animation states something."],
            ["Honesty is a design element", "Sources under every figure, aggregation only, a methodology page built with the same care as the home page."],
          ].map(([title, body], i) => (
            <li class="max-w-[42ch]">
              <p class="t-meta mb-2">{String(i + 1).padStart(2, "0")}</p>
              <h3 class="t-serif text-xl">{title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-2">{body}</p>
            </li>
          ))
        }
      </ol>
    </section>

    <!-- Color -->
    <section class="border-b border-line py-16">
      <h2 class="t-serif mb-2 text-3xl">Color</h2>
      <p class="mb-10 max-w-[60ch] text-sm text-ink-2">
        One accent. The palette works in luminance steps, not in hues.
        Light mode swaps the same roles onto cool paper.
      </p>
      <div class="grid gap-x-8 gap-y-6 sm:grid-cols-2 lg:grid-cols-4" data-reveal-stagger>
        {
          darkColors.map((c) => (
            <div>
              <div
                class="h-20 border border-line-2 rounded-r1"
                style={`background:${c.hex}`}
              />
              <p class="t-meta mt-2">{c.token} · {c.hex}</p>
              <p class="mt-1 text-sm text-ink-2">{c.role}</p>
            </div>
          ))
        }
      </div>

      <h3 class="t-serif mt-14 mb-4 text-xl">Measured contrast</h3>
      <div class="max-w-xl overflow-x-auto">
        <table class="data-table">
          <thead>
            <tr><th>Pair</th><th class="num">Ratio</th><th>WCAG</th></tr>
          </thead>
          <tbody>
            {
              contrast.map((r) => (
                <tr>
                  <td>{r.pair}</td>
                  <td class="num font-mono text-[13px]">{r.ratio}:1</td>
                  <td>{r.grade}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    <!-- Typography -->
    <section class="border-b border-line py-16">
      <h2 class="t-serif mb-2 text-3xl" data-reveal>Typography</h2>
      <p class="mb-12 max-w-[60ch] text-sm text-ink-2">
        Spectral carries the argument, Archivo runs the instruments,
        IBM Plex Mono keeps the ship's log.
      </p>

      <div class="grid gap-10" data-reveal-stagger>
        {
          typeScale.map((t) => (
            <div class="grid items-baseline gap-2 md:grid-cols-12">
              <p class="t-meta md:col-span-2">{t.name}<br />{t.size}</p>
              <p class={`${t.cls} md:col-span-10`} style={`font-size:${t.size}`}>
                {t.sample}
              </p>
            </div>
          ))
        }
        <div class="grid items-baseline gap-2 md:grid-cols-12">
          <p class="t-meta md:col-span-2">Editorial body<br />18px / 1.65</p>
          <p class="t-editorial md:col-span-10 max-w-[62ch]">
            Transits through Bab el-Mandeb fell below thirty per week for the
            first time since tracking began, while insurers widened the listed
            area to the entire southern Red Sea. <em>Rates followed within days.</em>
          </p>
        </div>
        <div class="grid items-baseline gap-2 md:grid-cols-12">
          <p class="t-meta md:col-span-2">UI body<br />16px Archivo</p>
          <p class="md:col-span-10 max-w-[62ch] text-ink-2">
            Interface text is set in Archivo. Labels stay short, sentence case,
            and never compete with the data they describe.
          </p>
        </div>
        <div class="grid items-baseline gap-2 md:grid-cols-12">
          <p class="t-meta md:col-span-2">Taxonomy<br />small caps</p>
          <p class="t-caps md:col-span-10">Southern Red Sea · war risk zone</p>
        </div>
        <div class="grid items-baseline gap-2 md:grid-cols-12">
          <p class="t-meta md:col-span-2">Ship's log<br />mono 12px</p>
          <p class="t-meta md:col-span-10">12°39'N 43°25'E · 2026-07-08 14:32 UTC · UKMTO advisory 044</p>
        </div>
        <div class="grid items-baseline gap-2 md:grid-cols-12">
          <p class="t-meta md:col-span-2">Tabular figures</p>
          <div class="md:col-span-10">
            <p class="t-num font-sans text-2xl">1,084 → 42 → 30,660</p>
            <p class="mt-1 text-sm text-ink-3">Every number that meets another number aligns on a fixed grid.</p>
          </div>
        </div>
      </div>

      <!-- Serif alternative -->
      <div class="mt-16 grid gap-8 border-t border-line pt-10 lg:grid-cols-2" data-reveal-stagger>
        <div>
          <p class="t-caps mb-4">Recommended · Spectral</p>
          <p class="t-display text-[2.6rem]">Suez transits have halved since November</p>
          <p class="mt-3 text-sm text-ink-2 max-w-[46ch]">
            Cool, transitional, close to the register of a broadsheet.
            The optical axis sharpens at display sizes. This is the voice
            of measured authority.
          </p>
        </div>
        <div>
          <p class="t-caps mb-4">Alternative · Fraunces</p>
          <p
            class="text-[2.6rem]"
            style="font-family:'Fraunces Variable',serif;font-weight:500;line-height:1.02;letter-spacing:-0.015em;font-variation-settings:'opsz' 72"
          >
            Suez transits have halved since November
          </p>
          <p class="mt-3 text-sm text-ink-2 max-w-[46ch]">
            Warmer, softer terminals, more personality but less gravitas.
            Kept here for comparison; one of the two ships, not both.
          </p>
        </div>
      </div>
    </section>

    <!-- Iconography -->
    <section class="border-b border-line py-16">
      <h2 class="t-serif mb-2 text-3xl">Iconography</h2>
      <p class="mb-10 max-w-[60ch] text-sm text-ink-2">
        A custom maritime set: 20 px grid, 1.5 stroke, square terminals,
        drawn to sit next to IBM Plex Mono.
      </p>
      <div class="grid grid-cols-3 gap-px bg-[color:var(--line)] sm:grid-cols-4 lg:grid-cols-6" data-reveal-stagger>
        {
          icons.map((i) => (
            <div class="flex flex-col items-center gap-3 bg-bg-0 py-8 transition-colors duration-200 hover:bg-bg-1">
              <Icon name={i.name} size={24} class="text-ink" />
              <span class="t-meta">{i.label}</span>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Components -->
    <section class="border-b border-line py-16">
      <h2 class="t-serif mb-10 text-3xl" data-reveal>Components</h2>

      <div class="grid gap-14" data-reveal-stagger>
        <div>
          <p class="t-caps mb-4">Actions</p>
          <div class="flex flex-wrap items-center gap-4">
            <Button>Read the brief</Button>
            <Button variant="secondary">Cite this figure</Button>
            <Button variant="ghost">All incidents <Icon name="arrow" size={16} /></Button>
          </div>
          <p class="t-meta mt-3">Hover raises, active presses. Focus draws a 2 px amber ring.</p>
        </div>

        <div>
          <p class="t-caps mb-4">Taxonomy tags</p>
          <div class="flex flex-wrap gap-2">
            <Tag label="Drone strike" viz={1} />
            <Tag label="Boarding" viz={2} />
            <Tag label="Seizure" viz={3} />
            <Tag label="GPS jamming" viz={6} />
            <Tag label="Critical" risk />
            <Tag label="Bab el-Mandeb" />
          </div>
          <p class="t-meta mt-3">The square matches the series color of the same category in every chart.</p>
        </div>

        <div>
          <p class="t-caps mb-4">Live statistics</p>
          <div class="grid gap-8 sm:grid-cols-3">
            <Stat value={147} label="Incidents · last 30 days" detail="all monitored zones" accent />
            <Stat value={28} label="Bab el-Mandeb transits" detail="weekly, cargo above 10k dwt" />
            <Stat value={312} label="AIS anomalies flagged" detail="aggregated by zone" />
          </div>
        </div>

        <div>
          <p class="t-caps mb-4">Data table</p>
          <div class="overflow-x-auto">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Zone</th>
                  <th>Type</th>
                  <th class="num">Incidents 30d</th>
                  <th class="num">Trend</th>
                  <th>Last event · UTC</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Southern Red Sea</td>
                  <td>Drone strike</td>
                  <td class="num">23</td>
                  <td class="num text-risk-text">+9</td>
                  <td class="font-mono text-[13px]">2026-07-08 14:32</td>
                </tr>
                <tr>
                  <td>Gulf of Aden</td>
                  <td>Boarding</td>
                  <td class="num">7</td>
                  <td class="num">+1</td>
                  <td class="font-mono text-[13px]">2026-07-05 03:11</td>
                </tr>
                <tr>
                  <td>Strait of Hormuz</td>
                  <td>GPS jamming</td>
                  <td class="num">41</td>
                  <td class="num text-risk-text">+17</td>
                  <td class="font-mono text-[13px]">2026-07-09 21:47</td>
                </tr>
                <tr>
                  <td>Gulf of Guinea</td>
                  <td>Hijack</td>
                  <td class="num">2</td>
                  <td class="num text-ink-3">0</td>
                  <td class="font-mono text-[13px]">2026-06-28 06:54</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="t-meta mt-3">Sample rows. Numerals tabular, negative space instead of card chrome.</p>
        </div>
      </div>
    </section>

    <!-- Dataviz -->
    <section class="border-b border-line py-16">
      <h2 class="t-serif mb-2 text-3xl" data-reveal>Dataviz theme</h2>
      <p class="mb-10 max-w-[62ch] text-sm text-ink-2">
        One theme shared by every chart. Categorical order is fixed and
        CVD-validated (worst adjacent ΔE 31.2); the hero series wears the beam.
      </p>

      <div class="mb-12 flex flex-wrap gap-6" data-reveal-stagger>
        {
          vizSeries.map((s) => (
            <div class="flex items-center gap-2">
              <span class="inline-block h-4 w-4 rounded-r1" style={`background:var(--viz-${s.n})`} />
              <span class="text-sm text-ink-2">{s.name}</span>
              <span class="t-meta">{s.use}</span>
            </div>
          ))
        }
      </div>

      <div class="grid gap-16 lg:grid-cols-2">
        <Figure
          title="Bab el-Mandeb transits fell by two thirds"
          subtitle="Weekly transits, cargo vessels above 10k dwt. Sample data."
          source="Source: sample data for the styleguide"
        >
          <HeroLineChart client:visible />
        </Figure>
        <Figure
          title="Jamming now drives the incident count"
          subtitle="Monthly incidents by type, Jan to Jun. Sample data."
          source="Source: sample data for the styleguide"
        >
          <StackedBarChart client:visible />
        </Figure>
      </div>
      <div class="mt-16 max-w-2xl">
        <Figure
          title="Six chokepoints, one glance"
          subtitle="Weekly transits per chokepoint, indexed scales. Sample data."
          source="Source: sample data for the styleguide"
        >
          <SmallMultiples client:visible />
        </Figure>
      </div>
    </section>

    <!-- Map -->
    <section class="border-b border-line py-16">
      <h2 class="t-serif mb-2 text-3xl" data-reveal>Map style · Abyss</h2>
      <p class="mb-10 max-w-[62ch] text-sm text-ink-2">
        A custom MapLibre style built for the observatory: water is the page
        itself, land recedes, no roads, no cities without purpose. Amber marks
        observations, red marks incidents.
      </p>
      <MapPanel client:visible />
      <p class="t-meta mt-3">Vector tiles by OpenFreeMap, style "Abyss" by Le Phare · markers are sample data</p>
    </section>

    <!-- Motion -->
    <section class="border-b border-line py-16">
      <h2 class="t-serif mb-2 text-3xl" data-reveal>Motion</h2>
      <p class="mb-10 max-w-[62ch] text-sm text-ink-2" data-reveal>
        Three durations, one curve. Every animation has an editorial meaning;
        under prefers-reduced-motion everything degrades to its final state.
      </p>

      <div class="mb-14 overflow-x-auto" data-reveal>
        <table class="data-table max-w-3xl">
          <thead>
            <tr><th>Gesture</th><th>Meaning</th><th>Tool</th></tr>
          </thead>
          <tbody>
            <tr>
              <td>Beam sweep, on load then every 9 s</td>
              <td>the observatory is on watch</td>
              <td class="font-mono text-[13px]">CSS keyframes</td>
            </tr>
            <tr>
              <td>Masthead lines rise from a mask</td>
              <td>the argument opens the page</td>
              <td class="font-mono text-[13px]">GSAP SplitText</td>
            </tr>
            <tr>
              <td>Sections reveal on scroll, staggered</td>
              <td>density arrives in layers</td>
              <td class="font-mono text-[13px]">GSAP ScrollTrigger</td>
            </tr>
            <tr>
              <td>Charts draw themselves in viewport</td>
              <td>the data is being traced</td>
              <td class="font-mono text-[13px]">Web Animations API</td>
            </tr>
            <tr>
              <td>Shipping-lane particles in the hero</td>
              <td>traffic keeps moving through the dark</td>
              <td class="font-mono text-[13px]">Canvas 2D</td>
            </tr>
            <tr>
              <td>Map: camera drift, lane flow, pulsing incidents</td>
              <td>the watch room leans in</td>
              <td class="font-mono text-[13px]">MapLibre native</td>
            </tr>
            <tr>
              <td>Counters count up, light streak on primary CTA</td>
              <td>the data is alive; the beam passes</td>
              <td class="font-mono text-[13px]">rAF · CSS</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="grid gap-6 md:grid-cols-3" data-reveal-stagger>
        <div class="border-t border-line-2 pt-3">
          <p class="t-num font-mono text-2xl">150ms</p>
          <p class="t-caps mt-2 !text-ink-2">Hover, focus</p>
          <p class="t-meta mt-1">the promise of an action</p>
        </div>
        <div class="border-t border-line-2 pt-3">
          <p class="t-num font-mono text-2xl">200ms</p>
          <p class="t-caps mt-2 !text-ink-2">State changes</p>
          <p class="t-meta mt-1">filters, tabs, toggles</p>
        </div>
        <div class="border-t border-line-2 pt-3">
          <p class="t-num font-mono text-2xl">250ms</p>
          <p class="t-caps mt-2 !text-ink-2">Entrances</p>
          <p class="t-meta mt-1">layers, counters, reveals</p>
        </div>
      </div>
      <p class="t-meta mt-8">easing: cubic-bezier(0.16, 1, 0.3, 1) · the beam sweep on load runs once, 1.6 s</p>
    </section>

    <!-- Footer -->
    <footer class="py-12">
      <p class="t-meta max-w-[70ch]">
        Independent student research. Not insurance, navigation or security
        advice. Aggregated open-source data; may contain errors.
      </p>
    </footer>
  </div>

  <script>
    // Scroll choreography — GSAP ScrollTrigger + SplitText (both free since 3.13).
    // Guarded by matchMedia: reduced-motion users get the finished layout.
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { SplitText } from "gsap/SplitText";

    gsap.registerPlugin(ScrollTrigger, SplitText);

    const mm = gsap.matchMedia();
    mm.add("(prefers-reduced-motion: no-preference)", () => {
      // wait for Spectral before splitting lines, or breaks land wrong
      document.fonts.ready.then(() => {
        const title = document.getElementById("masthead-title");
        if (title) {
          const split = SplitText.create(title, { type: "lines", mask: "lines" });
          gsap.from(split.lines, {
            yPercent: 115,
            duration: 1.1,
            ease: "power4.out",
            stagger: 0.14,
            delay: 0.1,
          });
        }
      });

      for (const el of gsap.utils.toArray<HTMLElement>("[data-reveal]")) {
        gsap.from(el, {
          y: 24,
          autoAlpha: 0,
          duration: 0.8,
          ease: "power3.out",
          scrollTrigger: { trigger: el, start: "top 88%" },
        });
      }
      for (const el of gsap.utils.toArray<HTMLElement>("[data-reveal-stagger]")) {
        gsap.from(el.children, {
          y: 26,
          autoAlpha: 0,
          duration: 0.7,
          ease: "power3.out",
          stagger: 0.07,
          scrollTrigger: { trigger: el, start: "top 85%" },
        });
      }
    });
  </script>

  <script>
    const btn = document.getElementById("theme-toggle")!;
    const setLabel = () => {
      const light = document.documentElement.dataset.theme === "light";
      btn.textContent = light ? "Dark mode" : "Light mode";
      btn.setAttribute("aria-pressed", String(light));
    };
    btn.addEventListener("click", () => {
      const light = document.documentElement.dataset.theme === "light";
      if (light) {
        delete document.documentElement.dataset.theme;
        localStorage.setItem("phare-theme", "dark");
      } else {
        document.documentElement.dataset.theme = "light";
        localStorage.setItem("phare-theme", "light");
      }
      setLabel();
    });
    setLabel();
  </script>
</Base>
