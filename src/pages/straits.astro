---
import Base from "../layouts/Base.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Sparkline from "../components/ui/Sparkline.astro";
import LiveStraits from "../components/straits/LiveStraits";
import weekly from "../data/transits-weekly.json";
import { weekLabel } from "../lib/week";

// Real weekly transit calls from IMF PortWatch (all vessel types).
const ORDER = ["bab-el-mandeb", "suez", "good-hope", "hormuz", "malacca", "gibraltar", "panama", "bosphorus", "danish-straits", "dover", "taiwan-strait", "kerch"];
const chokepoints = ORDER.map((slug) => {
  const c = (weekly.chokepoints as any)[slug];
  return { slug, name: c.name, pts: c.weekly.map((e: any) => e.t), value: c.last, delta: c.delta, week: c.week };
});
const rerouting = weekly.rerouting.at(-1);
---

<Base
  title="Strait Transit Monitor · Le Phare"
  description="Weekly transits across the world's chokepoints, the Suez-versus-Cape rerouting index, and live AIS over the Baltic approaches."
>
  <SiteHeader />

  <div class="mx-auto max-w-[1320px] px-6">
    <section class="border-b border-line py-16 md:py-20">
      <h1 class="t-display max-w-[16ch] text-[clamp(2.4rem,5vw,4rem)]">
        Strait Transit Monitor
      </h1>
      <p class="mt-6 max-w-[56ch] text-lg leading-relaxed text-ink-2">
        Twelve chokepoints, watched weekly against their 2024-25 baseline,
        with a live AIS picture of each. Every strait has its own page.
      </p>
    </section>

    <!-- Live panel -->
    <section class="border-b border-line py-14">
      <h2 class="t-serif mb-2 text-3xl">Live watch</h2>
      <p class="mb-8 max-w-[62ch] text-sm text-ink-2">
        Pick a strait; the map connects to its live AIS feed. The Baltic is a
        full snapshot (Digitraffic); the world's straits accumulate broadcasts
        as they arrive (aisstream.io), a busy strait fills within seconds.
      </p>
      <LiveStraits client:load />
    </section>

    <!-- Chokepoint grid -->
    <section class="py-14">
      <h2 class="t-serif mb-2 text-3xl">Weekly transits</h2>
      <p class="mb-10 max-w-[62ch] text-sm text-ink-2">
        Vessel transit calls per week, all types, last 27 weeks. Real data
        from IMF PortWatch, updated weekly. Build your own view in the{" "}
        <a href="/data" class="link">data lab</a>.
      </p>
      <div class="grid gap-x-10 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
        {
          chokepoints.map((c) => (
            <a href={`/straits/${c.slug}`} id={c.slug} class="group block scroll-mt-28 border-t border-line-2 pt-4 transition-colors duration-150 target:bg-accent-wash">
              <p class="t-serif text-xl transition-colors duration-150 group-hover:text-accent-text">{c.name}</p>
              {(weekly.chokepoints as any)[c.slug].status !== "normal" && (
                <p class={`mt-1.5 border-l-2 pl-2.5 ${(weekly.chokepoints as any)[c.slug].status === "critical" ? "border-[color:var(--risk)]" : "border-[color:var(--accent)]"}`}>
                  <span class={`t-caps ${(weekly.chokepoints as any)[c.slug].status === "critical" ? "!text-risk-text" : "!text-accent-text"}`}>
                    <span class="mr-1.5 inline-block size-[7px] align-middle" style={`background:${(weekly.chokepoints as any)[c.slug].status === "critical" ? "var(--risk)" : "var(--accent)"}`} />
                    {(weekly.chokepoints as any)[c.slug].status}
                  </span>
                  <span class="t-meta ml-2">
                    {(weekly.chokepoints as any)[c.slug].pct}% of its 2024-25 baseline · {c.value}/wk vs ~{(weekly.chokepoints as any)[c.slug].baseline}
                    {(weekly.chokepoints as any)[c.slug].trend ? ` · ${(weekly.chokepoints as any)[c.slug].trend}` : ""}
                  </span>
                </p>
              )}
              <Sparkline points={c.pts} width={200} height={44} class="mt-3" />
              <p class="t-meta t-num mt-2">
                {c.value} in {weekLabel(c.week)}
                <span class={c.delta > 0 ? "!text-[color:var(--viz-2)]" : c.delta < 0 ? "!text-risk-text" : ""}>
                  {" "}{c.delta > 0 ? `+${c.delta}` : c.delta === 0 ? "±0" : c.delta}
                </span>
                <span class="t-meta ml-2 opacity-0 transition-opacity duration-150 group-hover:opacity-100">state of the strait →</span>
              </p>
            </a>
          ))
        }
      </div>
      <p class="t-meta mt-12 border-t border-line pt-4">
        Rerouting index (Cape vs Suez): {rerouting?.idx} in {rerouting?.w.slice(5)} · above 1, the
        long way round carries more traffic · Source: IMF PortWatch, updated {weekly.updated}
      </p>
    </section>
  </div>

  <SiteFooter />
</Base>
