---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Button from "../components/ui/Button.astro";
import Stat from "../components/ui/Stat.astro";
import Icon from "../components/Icon.astro";
import Bathymetry from "../components/motifs/Bathymetry.astro";
import WindRose from "../components/motifs/WindRose.astro";
import ThreeGlobe from "../components/hero/ThreeGlobe";

const briefs = (await getCollection("briefs")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const latest = briefs[0];

const dateFmt = new Intl.DateTimeFormat("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const modules = [
  { href: "/incidents", icon: "mine", title: "Incident database", desc: "Geocoded and typed maritime incidents from public reporting, on a clustered map with filters and monthly trends.", status: "In build", span: "lg:col-span-7", motif: "bathy" },
  { href: "/straits", icon: "strait", title: "Strait monitor", desc: "Weekly transits and speeds across eleven chokepoints, plus the Suez-versus-Cape rerouting index.", status: "In build", span: "lg:col-span-5", motif: "" },
  { href: "/anomalies", icon: "jamming", title: "AIS integrity watch", desc: "Jamming clusters, impossible jumps and dark gaps, aggregated by zone.", status: "In build", span: "lg:col-span-4", motif: "" },
  { href: "/zones", icon: "vessel", title: "War risk zones atlas", desc: "How listed areas moved, circular by circular, over time.", status: "In build", span: "lg:col-span-4", motif: "rose" },
  { href: "/glossary", icon: "anchor", title: "Maritime risk lexicon", desc: "The vocabulary of shipping and marine insurance, defined precisely.", status: "In build", span: "lg:col-span-4", motif: "" },
] as const;
---

<Base
  title="Le Phare · Maritime Risk Observatory"
  description="Independent open-source monitoring of maritime incidents, chokepoint transits and AIS integrity."
>
  <SiteHeader />

  <!-- Hero -->
  <section class="relative min-h-[calc(100dvh-61px)] overflow-hidden border-b border-line">
    <div id="hero-globe-wrap" class="absolute inset-0">
      <ThreeGlobe client:load />
    </div>
    <!-- readability scrim behind the headline -->
    <div
      class="pointer-events-none absolute inset-0 hidden lg:block"
      style="background: radial-gradient(75% 80% at 22% 45%, var(--bg-0) 0%, transparent 58%)"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-0 lg:hidden"
      style="background: linear-gradient(to bottom, var(--bg-0) 10%, transparent 62%)"
    >
    </div>

    <div class="pointer-events-none relative mx-auto flex min-h-[calc(100dvh-61px)] max-w-[1320px] flex-col justify-center px-6 pb-24">
      <div class="pointer-events-auto max-w-[52ch]">
        <p class="t-caps mb-6" data-reveal>Maritime Risk Observatory</p>
        <h1 id="hero-title" class="t-display max-w-[20ch] text-[clamp(2.3rem,4.6vw,4.1rem)]">
          The world's sea lanes, watched through <em>the dark.</em>
        </h1>
        <p class="mt-6 max-w-[42ch] text-lg leading-relaxed text-ink-2" data-reveal>
          Maritime incidents, chokepoint transits and AIS integrity, read from
          open sources.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-5" data-reveal>
          <Button href="/brief">Read the weekly brief</Button>
          <Button href="/incidents" variant="ghost">Explore the incident map <Icon name="arrow" size={16} /></Button>
        </div>
      </div>
    </div>

    <p
      id="globe-readout"
      class="t-meta pointer-events-none absolute bottom-4 left-6 hidden md:block"
      aria-hidden="true"
    >
      CAM 048.0°E 14.0°N · VIIRS NIGHT
    </p>
    <p class="t-meta pointer-events-none absolute bottom-4 right-6">
      Night imagery: NASA VIIRS Black Marble
    </p>
  </section>

  <!-- Live figures -->
  <section class="border-b border-line">
    <div
      class="mx-auto grid max-w-[1320px] gap-y-8 px-6 py-12 sm:grid-cols-3 sm:divide-x sm:divide-[color:var(--line)] sm:[&>*]:px-8 sm:[&>*:first-child]:pl-0 sm:[&>*]:border-t-0"
      data-reveal-stagger
    >
      <Stat value={147} label="Incidents · last 30 days" detail="all monitored zones" accent />
      <Stat value={28} label="Bab el-Mandeb transits" detail="weekly, cargo above 10k dwt" />
      <Stat value={312} label="AIS anomalies flagged" detail="last 7 days, by zone" />
    </div>
  </section>

  <!-- Latest brief -->
  {
    latest && (
      <section class="border-b border-line">
        <div class="mx-auto grid max-w-[1320px] gap-10 px-6 py-20 md:grid-cols-12">
          <div class="md:col-span-4" data-reveal>
            <h2 class="t-serif text-3xl">This week's brief</h2>
            <p class="t-meta mt-3">
              No. {latest.data.issue} · {dateFmt.format(latest.data.date)}
            </p>
          </div>
          <a href={`/brief/${latest.id}`} class="group block md:col-span-8" data-reveal>
            <h3 class="t-serif text-[clamp(1.8rem,3.2vw,2.6rem)] transition-colors duration-200 group-hover:text-accent-text">
              {latest.data.title}
            </h3>
            <p class="t-editorial mt-4 max-w-[58ch] !text-[color:var(--ink-2)]">{latest.data.dek}</p>
            <span class="mt-6 inline-flex items-center gap-2 text-sm text-ink-2 transition-colors duration-200 group-hover:text-accent-text">
              Read issue no. {latest.data.issue} <Icon name="arrow" size={16} />
            </span>
          </a>
        </div>
      </section>
    )
  }

  <!-- Modules -->
  <section class="relative border-b border-line">
    <div class="mx-auto max-w-[1320px] px-6 py-20">
      <div class="mb-12 max-w-[56ch]" data-reveal>
        <h2 class="t-serif text-3xl">The observatory</h2>
        <p class="t-serif mt-4 text-xl !text-[color:var(--ink-2)]">
          We read the open data of the sea, so that risk is visible before it
          is priced. <a href="/methodology" class="link text-sm align-middle">How we work</a>
        </p>
      </div>
      <div class="grid gap-px bg-[color:var(--line)] sm:grid-cols-2 lg:grid-cols-12" data-reveal-stagger>
        {
          modules.map((m, i) => (
            <a
              href={m.href}
              class={`group relative flex flex-col justify-between overflow-hidden bg-bg-0 p-7 transition-colors duration-200 hover:bg-bg-1 ${m.span} ${i < 2 ? "min-h-[280px]" : "min-h-[220px]"}`}
            >
              {m.motif === "bathy" && <Bathymetry class="absolute inset-0 h-full w-full" opacity={0.07} />}
              {m.motif === "rose" && <WindRose size={220} opacity={0.07} class="absolute -bottom-14 -right-10" />}
              <span class="pointer-events-none absolute inset-x-0 top-0 h-px origin-left scale-x-0 bg-[color:var(--accent)] transition-transform duration-300 [transition-timing-function:var(--ease-out)] group-hover:scale-x-100"></span>
              <span class="relative flex items-start justify-between">
                <Icon name={m.icon} size={24} class="text-ink-2 transition-colors duration-200 group-hover:text-accent-text" />
                <span class="t-caps">{m.status}</span>
              </span>
              <span class="relative">
                <span class={`t-serif block transition-colors duration-200 group-hover:text-accent-text ${i < 2 ? "text-2xl" : "text-xl"}`}>{m.title}</span>
                <span class="mt-2 block max-w-[40ch] text-sm leading-relaxed text-ink-2">{m.desc}</span>
              </span>
              <span class="absolute bottom-6 right-6 translate-x-1 text-ink-3 opacity-0 transition-[opacity,transform] duration-200 [transition-timing-function:var(--ease-out)] group-hover:translate-x-0 group-hover:opacity-100 group-hover:text-accent-text">
                <Icon name="arrow" size={18} />
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <SiteFooter />

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { SplitText } from "gsap/SplitText";

    gsap.registerPlugin(ScrollTrigger, SplitText);

    // keep ScrollTrigger in sync with Lenis
    (window as any).__lenis?.on("scroll", ScrollTrigger.update);

    const mm = gsap.matchMedia();
    mm.add("(prefers-reduced-motion: no-preference)", () => {
      document.fonts.ready.then(() => {
        const title = document.getElementById("hero-title");
        if (title) {
          const split = SplitText.create(title, { type: "lines", mask: "lines" });
          gsap.from(split.lines, {
            yPercent: 115,
            duration: 1.1,
            ease: "power4.out",
            stagger: 0.13,
            delay: 0.1,
          });
        }
      });

      // the globe recedes slightly as you leave the hero
      gsap.to("#hero-globe-wrap", {
        yPercent: 10,
        opacity: 0.55,
        ease: "none",
        scrollTrigger: {
          trigger: "#hero-globe-wrap",
          start: "top top",
          end: "bottom top",
          scrub: true,
        },
      });

      for (const el of gsap.utils.toArray<HTMLElement>("[data-reveal]")) {
        gsap.from(el, {
          y: 24,
          autoAlpha: 0,
          duration: 0.8,
          ease: "power3.out",
          scrollTrigger: { trigger: el, start: "top 88%" },
        });
      }
      for (const el of gsap.utils.toArray<HTMLElement>("[data-reveal-stagger]")) {
        gsap.from(el.children, {
          y: 26,
          autoAlpha: 0,
          duration: 0.7,
          ease: "power3.out",
          stagger: 0.08,
          scrollTrigger: { trigger: el, start: "top 85%" },
        });
      }
    });
  </script>
</Base>
