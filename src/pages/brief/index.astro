---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import Icon from "../../components/Icon.astro";

const briefs = (await getCollection("briefs")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const dateFmt = new Intl.DateTimeFormat("en-GB", { day: "numeric", month: "long", year: "numeric" });
---

<Base
  title="Weekly Maritime Risk Brief · Le Phare"
  description="Three hundred words and one chart on maritime risk, every Monday. Archive of all issues."
>
  <SiteHeader />

  <div class="mx-auto max-w-[1320px] px-6">
    <section class="border-b border-line py-16 md:py-20">
      <h1 class="t-display max-w-[16ch] text-[clamp(2.4rem,5vw,4rem)]">
        Weekly Maritime Risk Brief
      </h1>
      <p class="mt-6 max-w-[52ch] text-lg leading-relaxed text-ink-2">
        Three hundred words and one chart, every Monday. What moved on the
        world's sea lanes, and what it means for risk.
      </p>
      <p class="t-meta mt-4">
        <a href="/rss.xml" class="link">RSS</a> · free, no signup
      </p>
    </section>

    <section class="py-14">
      <ol class="grid gap-0">
        {
          briefs.map((b) => (
            <li>
              <a
                href={`/brief/${b.id}`}
                class="group grid gap-3 border-b border-line py-8 transition-colors duration-200 hover:bg-bg-1 md:grid-cols-12 md:gap-6 md:px-4"
              >
                <span class="t-meta md:col-span-2">
                  No. {b.data.issue}
                  <br />
                  {dateFmt.format(b.data.date)}
                </span>
                <span class="md:col-span-9">
                  <span class="t-serif block text-2xl transition-colors duration-200 group-hover:text-accent-text">
                    {b.data.title}
                  </span>
                  <span class="mt-2 block max-w-[64ch] text-sm leading-relaxed text-ink-2">{b.data.dek}</span>
                </span>
                <span class="hidden items-center justify-end text-ink-3 transition-colors duration-200 group-hover:text-accent-text md:col-span-1 md:flex">
                  <Icon name="arrow" size={18} />
                </span>
              </a>
            </li>
          ))
        }
      </ol>
    </section>
  </div>

  <SiteFooter />
</Base>
