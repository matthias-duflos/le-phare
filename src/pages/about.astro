---
import Base from "../layouts/Base.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Logo from "../components/Logo.astro";
import { LINKEDIN_URL, CONTACT_EMAIL } from "../lib/identity";

// [PLACEHOLDER] — the bio below is explicitly marked for Matthias to replace
// with his real details. LinkedIn and contact live in src/lib/identity.ts
// and are omitted from the page while unset.
---

<Base
  title="About · Le Phare"
  description="Who runs the maritime risk observatory, why it exists, and how to reach out."
>
  <SiteHeader />

  <div class="mx-auto max-w-[1320px] px-6">
    <section class="border-b border-line py-16 md:py-20">
      <Logo size={44} />
      <h1 class="t-display mt-6 max-w-[14ch] text-[clamp(2.4rem,5vw,4rem)]">About Le Phare</h1>
      <div class="t-editorial mt-8 grid max-w-[62ch] gap-5">
        <p>
          <mark class="bg-accent-wash text-ink">[PLACEHOLDER — five lines:
          student profile, programme, the maritime/insurance interest, one
          concrete credential, one human detail.]</mark>
        </p>
        <p>
          Le Phare began as a simple observation: the data that moves marine
          insurance, transits, incidents, signal integrity, is largely public,
          yet almost nowhere is it read carefully in the open. A lighthouse
          does not chase ships; it stands still and makes the water legible.
          This site tries to do the same with open data.
        </p>
        <p>
          Everything here is independent student research: no client, no
          affiliation, no market position. The methodology page says where
          the data is weak; the sources page says where it comes from.
        </p>
      </div>
      <p class="mt-10 flex flex-wrap gap-5">
        {LINKEDIN_URL && <a href={LINKEDIN_URL} rel="me noopener" class="link text-sm">LinkedIn</a>}
        {CONTACT_EMAIL && <a href={`mailto:${CONTACT_EMAIL}`} class="link text-sm">{CONTACT_EMAIL}</a>}
        <a href="/rss.xml" class="link text-sm">RSS</a>
      </p>
    </section>
  </div>

  <SiteFooter />
</Base>
