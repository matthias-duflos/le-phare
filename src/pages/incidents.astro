---
import Base from "../layouts/Base.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import IncidentExplorer from "../components/incidents/IncidentExplorer";
import NavWarnings from "../components/incidents/NavWarnings";
import AlertsFeed from "../components/data/AlertsFeed";
import incidents from "../data/incidents.json";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  name: "Le Phare Maritime Incident Database (sample)",
  description:
    "Geocoded and typed maritime security incidents aggregated from public reporting. Sample data demonstrating the format.",
  creator: { "@type": "Organization", name: "Le Phare" },
  license: "https://creativecommons.org/licenses/by/4.0/",
};
---

<Base
  title="Maritime Incident Database · Le Phare"
  description="Geocoded and typed maritime incidents from public reporting: drone strikes, boardings, seizures, mines, hijacks and GPS jamming, mapped and charted."
>
  <SiteHeader />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="mx-auto max-w-[1320px] px-6">
    <section class="border-b border-line py-16 md:py-20">
      <h1 class="t-display max-w-[18ch] text-[clamp(2.4rem,5vw,4rem)]">
        Maritime Incident Database
      </h1>
      <p class="mt-6 max-w-[58ch] text-lg leading-relaxed text-ink-2">
        Geocoded and typed hostile acts against ships, with vessel details
        where publicly reported. Two datasets: the real NGA ASAM archive of
        677 events (2022 to June 2024, public domain, including vessel names
        and flags), and 2026 incidents curated from public reporting of the
        Hormuz crisis, source linked on every event.
      </p>
      <p class="t-meta mt-4">
        The ASAM programme was defunded on 30 June 2024, which is why the
        archive stops there · 2026 curation grows weekly with the brief
      </p>
    </section>

    <section class="border-b border-line py-12">
      <IncidentExplorer client:load />
    </section>

    <section class="grid gap-14 py-12 lg:grid-cols-2">
      <div>
        <h2 class="t-serif mb-2 text-3xl">Active official warnings</h2>
        <p class="mb-6 max-w-[52ch] text-sm text-ink-2">
          Current NAVAREA and HYDRO broadcast warnings with a security
          dimension: firings, launchings, mines, ordnance, interference.
          Official, current, public domain.
        </p>
        <NavWarnings client:visible />
      </div>
      <div>
        <h2 class="t-serif mb-2 text-3xl">Live alerts wire</h2>
        <p class="mb-6 max-w-[52ch] text-sm text-ink-2">
          Worldwide news mentions of maritime-risk events over the last seven
          days, raw and unverified. What survives verification enters the
          record above on Mondays.
        </p>
        <AlertsFeed max={18} timespan="7d" client:visible />
      </div>
    </section>
  </div>

  <SiteFooter />
</Base>
