---
// Watch-room ticker at the base of the hero. Sample feed until the
// incident pipeline ships (and it says so). One marquee per page, max.
const items: Array<{ time?: string; type: string; text: string; viz?: number; risk?: boolean }> = [
  { time: "14:32 UTC", type: "Drone strike", text: "Southern Red Sea", risk: true },
  { time: "11:07 UTC", type: "GPS jamming", text: "Strait of Hormuz", viz: 6 },
  { time: "09:54 UTC", type: "Boarding", text: "Gulf of Aden", viz: 2 },
  { type: "Transits W28", text: "Bab el-Mandeb 28 · Suez 41" },
  { time: "06:12 UTC", type: "Dark gap 11h", text: "Gulf of Guinea", viz: 3 },
  { type: "Rerouting index", text: "Cape vs Suez 2.4" },
  { time: "03:41 UTC", type: "Seizure", text: "Approaches to Hormuz", viz: 4 },
];
const loop = [...items, ...items];
---

<div
  class="ticker-wrap absolute inset-x-0 bottom-0 overflow-hidden border-t border-line bg-bg-0/75 backdrop-blur-sm"
  aria-hidden="true"
>
  <div class="ticker flex w-max items-center gap-12 py-2.5 pr-12">
    {
      loop.map((i) => (
        <span class="t-meta flex items-center gap-2 whitespace-nowrap">
          {(i.viz || i.risk) && (
            <span
              class="inline-block size-[6px]"
              style={`background:${i.risk ? "var(--risk)" : `var(--viz-${i.viz})`}`}
            />
          )}
          {i.time && <span>{i.time}</span>}
          <span class="!text-ink-2 uppercase tracking-[0.1em]">{i.type}</span>
          <span>{i.text}</span>
        </span>
      ))
    }
    <span class="t-meta whitespace-nowrap">sample feed · live with the incident database</span>
  </div>
</div>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .ticker {
      animation: ticker-scroll 55s linear infinite;
    }
    .ticker-wrap:hover .ticker {
      animation-play-state: paused;
    }
    @keyframes ticker-scroll {
      to {
        transform: translateX(-50%);
      }
    }
  }
</style>
