---
// Bathymetric contour motif — sits behind content at 4-6% opacity.
// Depth soundings drawn as nested isolines, like a nautical chart.
interface Props {
  class?: string;
  opacity?: number;
}
const { class: className = "", opacity = 0.05 } = Astro.props;
---

<svg
  viewBox="0 0 900 420"
  fill="none"
  stroke="var(--ink)"
  stroke-width="1"
  aria-hidden="true"
  class={`pointer-events-none select-none ${className}`}
  style={`opacity:${opacity}`}
  preserveAspectRatio="xMidYMid slice"
>
  <path d="M-20 80 C 120 40, 260 130, 420 96 S 700 30, 920 90" />
  <path d="M-20 140 C 140 96, 300 190, 460 150 S 720 90, 920 150" />
  <path d="M-20 205 C 150 155, 330 250, 500 205 S 740 150, 920 215" />
  <path d="M-20 275 C 160 220, 350 315, 530 265 S 760 215, 920 280" />
  <path d="M-20 345 C 170 290, 370 380, 560 330 S 780 285, 920 350" />
  <path d="M120 108 C 200 88, 280 128, 360 112" stroke-dasharray="1 6" />
  <path d="M480 240 C 570 218, 650 262, 730 240" stroke-dasharray="1 6" />
  <text x="212" y="132" font-family="var(--font-mono)" font-size="11" fill="var(--ink)" stroke="none">200</text>
  <text x="420" y="268" font-family="var(--font-mono)" font-size="11" fill="var(--ink)" stroke="none">1000</text>
  <text x="640" y="362" font-family="var(--font-mono)" font-size="11" fill="var(--ink)" stroke="none">2000</text>
</svg>
