---
// LE PHARE mark — hand-drawn lighthouse, amber beam sweeps once on load.
// Hand-rolled SVG is deliberate here: the brief mandates custom maritime assets.
interface Props {
  size?: number;
  sweep?: boolean;
  class?: string;
}
const { size = 28, sweep = true, class: className = "" } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  aria-hidden="true"
  class={className}
>
  <!-- beam -->
  <g
    class={sweep ? "beam-sweep" : ""}
    style="transform-origin: 13.4px 6.9px"
  >
    <path
      d="M13.6 5.9 L23 3.2 L23 6.4 Z"
      fill="var(--accent)"
      opacity="0.9"
    ></path>
    <path
      d="M13.6 5.9 L23 3.2 L23 6.4 Z"
      fill="url(#beam-fade)"
    ></path>
  </g>
  <defs>
    <linearGradient id="beam-fade" x1="13.6" y1="5" x2="23" y2="5" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="var(--bg-0)" stop-opacity="0"></stop>
      <stop offset="1" stop-color="var(--bg-0)" stop-opacity="0.55"></stop>
    </linearGradient>
  </defs>
  <!-- lamp room -->
  <rect x="10.6" y="4.9" width="3.2" height="2.4" stroke="var(--ink)" stroke-width="1.4" fill="none"></rect>
  <path d="M10.2 4.9 L12.2 3.2 L14.2 4.9" stroke="var(--ink)" stroke-width="1.4" fill="none" stroke-linejoin="miter"></path>
  <!-- tower, tapered -->
  <path d="M10.9 7.3 L9.7 20 L14.7 20 L13.5 7.3" stroke="var(--ink)" stroke-width="1.4" fill="none" stroke-linejoin="miter"></path>
  <!-- bands -->
  <line x1="10.5" y1="11.5" x2="13.9" y2="11.5" stroke="var(--ink)" stroke-width="1.4"></line>
  <line x1="10.1" y1="15.8" x2="14.3" y2="15.8" stroke="var(--ink)" stroke-width="1.4"></line>
  <!-- waterline -->
  <path d="M2 20 Q4.5 18.6 7 20 T12 20 T17 20 T22 20" stroke="var(--ink-3)" stroke-width="1.2" fill="none"></path>
</svg>
