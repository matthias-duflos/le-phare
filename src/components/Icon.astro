---
// Custom maritime icon set — 20px grid, 1.5 stroke, square caps.
// Geometric and consistent with JetBrains Mono terminals.
// Hand-drawn on purpose: the brief mandates a custom maritime iconography.
interface Props {
  name: keyof typeof icons;
  size?: number;
  class?: string;
}

const icons = {
  // naval mine: sphere + contact horns
  mine: `<circle cx="10" cy="11" r="4.6"/><line x1="10" y1="3.5" x2="10" y2="6.4"/><line x1="10" y1="15.6" x2="10" y2="18.5"/><line x1="2.5" y1="11" x2="5.4" y2="11"/><line x1="14.6" y1="11" x2="17.5" y2="11"/><line x1="4.7" y1="5.7" x2="6.75" y2="7.75"/><line x1="13.25" y1="14.25" x2="15.3" y2="16.3"/><line x1="15.3" y1="5.7" x2="13.25" y2="7.75"/><line x1="6.75" y1="14.25" x2="4.7" y2="16.3"/>`,
  // drone strike: quadcopter cross + rotors, descending
  drone: `<line x1="6" y1="6" x2="14" y2="14"/><line x1="14" y1="6" x2="6" y2="14"/><circle cx="5" cy="5" r="2.4"/><circle cx="15" cy="5" r="2.4"/><circle cx="5" cy="15" r="2.4"/><circle cx="15" cy="15" r="2.4"/><rect x="8.9" y="8.9" width="2.2" height="2.2" fill="currentColor" stroke="none"/>`,
  // boarding: ladder against a hull line
  boarding: `<line x1="7" y1="2.5" x2="7" y2="14.5"/><line x1="12" y1="2.5" x2="12" y2="14.5"/><line x1="7" y1="5.5" x2="12" y2="5.5"/><line x1="7" y1="8.5" x2="12" y2="8.5"/><line x1="7" y1="11.5" x2="12" y2="11.5"/><path d="M2 17.5 Q5 16.2 8 17.5 T14 17.5 T20 17.5" stroke-width="1.3"/>`,
  // seizure: padlock
  seizure: `<rect x="4.5" y="9" width="11" height="8"/><path d="M6.8 9 V6.2 A3.2 3.2 0 0 1 13.2 6.2 V9"/><line x1="10" y1="12" x2="10" y2="14.2"/>`,
  // hijack: vessel silhouette + alert bar
  hijack: `<path d="M2.5 13 H17.5 L15.2 16.8 H4.8 Z"/><rect x="7" y="9.6" width="6" height="3.4"/><line x1="16.5" y1="2.5" x2="16.5" y2="7"/><rect x="15.9" y="8.6" width="1.3" height="1.3" fill="currentColor" stroke="none"/>`,
  // GPS jamming: broadcast arcs, struck through
  jamming: `<circle cx="10" cy="14.5" r="1.4" fill="currentColor" stroke="none"/><path d="M6.5 11a5 5 0 0 1 7 0"/><path d="M4 8.4a8.5 8.5 0 0 1 12 0"/><line x1="3.5" y1="17" x2="16.5" y2="3.5"/>`,
  // vessel: cargo profile
  vessel: `<path d="M2 12.5 H18 L15.5 16.5 H4.5 Z"/><line x1="4.5" y1="12.5" x2="4.5" y2="9.5"/><rect x="6.5" y="9.5" width="3" height="3"/><rect x="10.5" y="9.5" width="3" height="3"/><line x1="15" y1="12.5" x2="15" y2="6.5"/>`,
  // anchor
  anchor: `<circle cx="10" cy="4.5" r="2"/><line x1="10" y1="6.5" x2="10" y2="16.5"/><line x1="6.5" y1="9" x2="13.5" y2="9"/><path d="M3.5 12.5 A6.5 6.5 0 0 0 16.5 12.5"/>`,
  // chokepoint: strait between two shores
  strait: `<path d="M3 2.5 Q8 6 7.5 10 T3 17.5"/><path d="M17 2.5 Q12 6 12.5 10 T17 17.5"/><line x1="10" y1="5.5" x2="10" y2="7"/><line x1="10" y1="9.5" x2="10" y2="11"/><line x1="10" y1="13.5" x2="10" y2="15"/>`,
  // trend arrow (up)
  trend: `<path d="M3 15 L8 9.5 L11.5 12.5 L17 5.5"/><path d="M12.5 5.5 H17 V10"/>`,
  // external link
  external: `<path d="M8 4.5 H4.5 V15.5 H15.5 V12"/><path d="M10.5 3 H17 V9.5"/><line x1="17" y1="3" x2="9.5" y2="10.5"/>`,
  // arrow right
  arrow: `<line x1="3" y1="10" x2="16.5" y2="10"/><path d="M11.5 4.5 L17 10 L11.5 15.5"/>`,
} as const;

const { name, size = 20, class: className = "" } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 20 20"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="square"
  stroke-linejoin="miter"
  aria-hidden="true"
  class={className}
  set:html={icons[name]}
/>
